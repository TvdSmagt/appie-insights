# User data and configuration files
data/*
!data/.gitkeep
config/*

# Database files
*.db
*.db-shm
*.db-wal

# Python cache files
__pycache__/
*.pyc
.pytest_cache/
# python venv
.venv*

# Built binaries, usually built by agents
login/login
backend/backend

# Packaging build outputs (the single-file executables and intermediates).
# The launcher's embedded zips (packaging/launcher/embedded/*.zip) are
# generated by the build scripts before the launcher is compiled and are NOT
# committed. See packaging/launcher/embedded/README.md.
/dist/
/build/
*.zip

# Local working notes
issues.md

# Editor and IDE specific files
.vscode
*.code-workspace

# We do not want to track the screenshots used to generate the carousel
docs/carousel/screenshots/*png

# AI Settings
.claude